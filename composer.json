{
    "name": "nazbav/yii2-account-balance",
    "description": "Расширение Yii2 для учёта баланса по модели дебет/кредит",
    "keywords": ["yii2", "balance", "accounting", "bookkeeping", "debit", "credit"],
    "type": "yii2-extension",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/nazbav/yii2-account-balance/issues",
        "forum": "http://www.yiiframework.com/forum/",
        "wiki": "https://github.com/nazbav/yii2-account-balance/wiki",
        "source": "https://github.com/nazbav/yii2-account-balance"
    },
    "authors": [
        {
            "name": "Nazbav",
            "email": "naz.bav@list.ru"
        }
    ],
    "require": {
        "php": "^8.1",
        "yiisoft/yii2": "~2.0.14"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "autoload": {
        "psr-4": {"nazbav\\balance\\": "src"}
    },
    "autoload-dev": {
        "psr-4": {
            "nazbav\\tests\\unit\\balance\\": "tests"
        }
    },
    "scripts": {
        "lint:syntax": "parallel-lint src tests",
        "cs:check": "php-cs-fixer fix --dry-run --diff --verbose",
        "cs:fix": "php-cs-fixer fix --verbose",
        "rector:check": "rector process --dry-run --ansi",
        "rector:fix": "rector process --ansi",
        "test": "phpunit -c phpunit.xml.dist",
        "test:mutation": "infection --threads=max --only-covered --filter=src/Manager.php,src/ManagerDb.php,src/ManagerActiveRecord.php --no-progress",
        "analyse": "phpstan analyse -c phpstan.neon --no-progress",
        "security:audit": "composer audit --locked",
        "security:taint": "psalm --taint-analysis --no-cache --output-format=console",
        "qa": [
            "@lint:syntax",
            "@cs:check",
            "@rector:check",
            "@test",
            "@analyse",
            "@security:taint",
            "@security:audit"
        ]
    },
    "extra": {
        "bootstrap": "nazbav\\balance\\Bootstrap",
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "infection/extension-installer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.12",
        "vimeo/psalm": "^5.26",
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan-phpunit": "^1.4",
        "friendsofphp/php-cs-fixer": "^3.94",
        "rector/rector": "^1.2",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpstan/phpstan-strict-rules": "^1.6.2",
        "phpstan/phpstan-deprecation-rules": "^1.2.1",
        "infection/infection": "^0.27.11"
    }
}
