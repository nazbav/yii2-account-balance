{
    "name": "yii2tech/balance",
    "description": "Provides support for Balance accounting system based on debit and credit principle",
    "keywords": ["yii2", "balance", "accounting", "bookkeeping", "debit", "credit"],
    "type": "yii2-extension",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yii2tech/balance/issues",
        "forum": "http://www.yiiframework.com/forum/",
        "wiki": "https://github.com/yii2tech/balance/wiki",
        "source": "https://github.com/yii2tech/balance"
    },
    "authors": [
        {
            "name": "Paul Klimov",
            "email": "klimov.paul@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "yiisoft/yii2": "~2.0.14"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "autoload": {
        "psr-4": {"yii2tech\\balance\\": "src"}
    },
    "autoload-dev": {
        "psr-4": {
            "yii2tech\\tests\\unit\\balance\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "analyse": "phpstan analyse -c phpstan.neon --no-progress",
        "security:audit": "composer audit --locked",
        "security:taint": "psalm --taint-analysis --no-cache --output-format=console",
        "qa": [
            "@test",
            "@analyse",
            "@security:audit",
            "@security:taint"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.12",
        "vimeo/psalm": "^5.26",
        "roave/security-advisories": "dev-latest"
    }
}
